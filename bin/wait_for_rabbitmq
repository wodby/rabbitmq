#!/usr/bin/env bash

set -e

if [[ -n "${DEBUG}" ]]; then
    set -x
fi

started=0
host=$1
port=$2
max_try=$3
wait_seconds=$4
delay_seconds=$5

sleep "${delay_seconds}"

ping_rabbitmq() {
    (echo >"/dev/tcp/${host}/${port}") >/dev/null 2>&1
}

for i in $(seq 1 "${max_try}"); do
    if ping_rabbitmq; then
        started=1
        break
    fi
    echo 'RabbitMQ is starting...'
    sleep "${wait_seconds}"
done

if [[ "${started}" -eq '0' ]]; then
    echo >&2 'Error. RabbitMQ is unreachable.'
    exit 1
fi

echo 'RabbitMQ has started!'
